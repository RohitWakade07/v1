# ── App ──────────────────────────────────────────────────────────────
APP_NAME="E-Yantra EEP Platform"
DEBUG=false
ENVIRONMENT=production

# ── Database ──────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=grading_user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=grading_db

# ── Redis (only used for rate limiting) ───────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ── JWT ───────────────────────────────────────────────────────────────
# generate: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=CHANGE_THIS_BEFORE_DEPLOYING
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Proof signing (HMAC-SHA256) ───────────────────────────────────────
# generate: python -c "import secrets; print(secrets.token_hex(64))"
# THIS KEY IS ALSO EMBEDDED IN THE COMPILED GRADER BINARY
PROOF_SIGNING_KEY=CHANGE_THIS_BEFORE_DEPLOYING

# ── Evaluator bootstrap ──────────────────────────────────────────────
# Shared key for /api/v1/sessions/start-evaluator
EVALUATOR_SHARED_KEY=
# ── Rate limiting ─────────────────────────────────────────────────────
LOGIN_RATE_LIMIT_PER_MINUTE=10
# ── Kafka ─────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# ── MinIO / S3 ────────────────────────────────────────────────────────
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_SUBMISSIONS=submissions
MINIO_BUCKET_ASSETS=grader-assets
MINIO_USE_SSL=false
MINIO_REGION=us-east-1
# ── EEP verifier (.eep1 / .eep2 / .eep3) ─────────────────────────────
RSA_PRIVATE_KEY_PATH=keys/instructor_private.pem
RSA_PRIVATE_KEY_B64=
EEP_MAX_UPLOAD_BYTES=50000
