# ── App ──────────────────────────────────────────────────────────────
APP_NAME="Secure Grading Platform"
DEBUG=false
ENVIRONMENT=production

# ── Database ──────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=grading_user
POSTGRES_PASSWORD=CHANGE_THIS
POSTGRES_DB=grading_db

# ── Redis (only used for rate limiting) ───────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ── JWT ───────────────────────────────────────────────────────────────
# generate: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=CHANGE_THIS_TO_LONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Proof signing (HMAC-SHA256) ───────────────────────────────────────
# generate: python -c "import secrets; print(secrets.token_hex(64))"
# THIS KEY IS ALSO EMBEDDED IN THE COMPILED GRADER BINARY
PROOF_SIGNING_KEY=CHANGE_THIS_TO_ANOTHER_LONG_RANDOM_SECRET

# ── Rate limiting ─────────────────────────────────────────────────────
LOGIN_RATE_LIMIT_PER_MINUTE=10
