# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME="Secure Grading Platform"
DEBUG=false
ENVIRONMENT=production

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=grading_user
POSTGRES_PASSWORD=CHANGE_THIS_PASSWORD
POSTGRES_DB=grading_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_HEARTBEAT_TIMEOUT_SECONDS=30
SESSION_MAX_DURATION_MINUTES=120

# ── Challenge signing ─────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
CHALLENGE_SIGNING_KEY=CHANGE_THIS_TO_ANOTHER_LONG_RANDOM_SECRET
