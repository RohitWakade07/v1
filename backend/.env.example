# ── App ──────────────────────────────────────────────────────────────
APP_NAME="E-Yantra EEP Platform"
DEBUG=false
ENVIRONMENT=production

# ── Database ──────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=grading_user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=grading_db

# ── Redis (only used for rate limiting) ───────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ── JWT ───────────────────────────────────────────────────────────────
# generate: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=90b5ef43e19c942feb0faa31098c503635d3e1403cdedcfc2add82d431713d050530bdbcfcfde1d80b36ab7053d9681b5958dc6ecc87e689b4d6b14a5d69b651
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Proof signing (HMAC-SHA256) ───────────────────────────────────────
# generate: python -c "import secrets; print(secrets.token_hex(64))"
# THIS KEY IS ALSO EMBEDDED IN THE COMPILED GRADER BINARY
PROOF_SIGNING_KEY=3ea77ef562113a93a15a613c7bf1d23b109f4dea557b572a2d52a44fbc3f823736f9a4bc18705cb2fbaead40556512ff40d4ce3d33e7e670c61aff25970512ba

# ── Evaluator bootstrap ──────────────────────────────────────────────
# Shared key for /api/v1/sessions/start-evaluator
EVALUATOR_SHARED_KEY=
# ── Rate limiting ─────────────────────────────────────────────────────
LOGIN_RATE_LIMIT_PER_MINUTE=10

# ── EEP verifier (.eep1 / .eep2 / .eep3) ─────────────────────────────
RSA_PRIVATE_KEY_PATH=keys/instructor_private.pem
RSA_PRIVATE_KEY_B64=
EEP_MAX_UPLOAD_BYTES=50000
