# Copy this to .env and fill in values
# On Railway: set these in the Variables tab

# Path to your RSA private key (on Railway: paste key content as env var instead)
PRIVATE_KEY_PATH=keys/instructor_private.pem

# Where to save decrypted submissions
UPLOADS_DIR=uploads

# Max upload size in bytes (default 50KB)
MAX_UPLOAD_BYTES=50000

# Port (Railway sets this automatically)
PORT=8080
